# ── Stripe ────────────────────────────────────────────────────
# Obtén estas claves en dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Price ID del producto recurrente (ver DEPLOY.md Paso 4)
STRIPE_PRICE_ID=price_...

# ── URL de tu app ──────────────────────────────────────────────
# Sin slash final
VITE_APP_URL=https://tu-app.vercel.app

# ── Precio que ve el usuario ───────────────────────────────────
VITE_PRICE_DISPLAY=$19

# ── Anthropic (Claude Advisor IA) ─────────────────────────────
# Obtén tu API key en console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (Auth) ────────────────────────────────────────────
# Crea proyecto gratis en supabase.com → Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Service Role Key — solo para server-side (api/). NUNCA expongas esto en el frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Resend (Emails transaccionales) ───────────────────────────
# Crea cuenta gratis en resend.com → API Keys
RESEND_API_KEY=re_...

# ── Stripe Webhook Secret ──────────────────────────────────────
# En dashboard.stripe.com → Webhooks → tu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
